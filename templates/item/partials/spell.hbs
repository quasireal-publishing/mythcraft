{{formGroup systemFields.magicSource value=system.magicSource options=system.magicSourceOptions localize=true disabled=isPlay}}
<div class="form-group">
  <label>{{systemFields.tags.label}}</label>
  <div class="form-fields">
    {{#if isPlay}}
    {{> "systems/mythcraft/templates/actor/partials/tag-display.hbs" tags=(resolveTags system.tags system.tagOptions)}}
    {{else}}
    <tag-input name="system.tags" data-suggestions="{{json system.tagOptions}}">
      {{#each system.tags}}
      <input type="hidden" name="system.tags" value="{{this}}">
      {{/each}}
    </tag-input>
    {{/if}}
  </div>
</div>
<div class="form-group">
  <div class="form-group inline slim">
    <label>{{systemFields.apc.label}}</label>
    <div class="form-fields">
      {{formInput systemFields.apc value=system.apc disabled=isPlay}}
    </div>
  </div>
  <div class="form-group inline slim">
    <label>{{systemFields.spc.label}}</label>
    <div class="form-fields">
      {{#if system.spcSpecial}}
      <span class="spc-special">Special</span>
      {{else}}
      {{formInput systemFields.spc value=system.spc disabled=isPlay}}
      {{/if}}
      {{formInput systemFields.spcSpecial value=system.spcSpecial disabled=isPlay}}
      <label class="checkbox-label">{{systemFields.spcSpecial.label}}</label>
    </div>
  </div>
</div>
<fieldset {{disabled isPlay}}>
  <legend>{{systemFields.range.label}}</legend>
  {{formGroup systemFields.range.fields.value value=system.range.value}}
  {{formGroup systemFields.range.fields.unit value=system.range.unit}}
</fieldset>
<div class="form-group">
  <label>{{systemFields.requirements.label}}</label>
  <div class="form-fields">
    {{#if isPlay}}
    {{> "systems/mythcraft/templates/actor/partials/tag-display.hbs" tags=(resolveTags system.requirements system.requirementOptions)}}
    {{else}}
    <tag-input name="system.requirements" data-suggestions="{{json system.requirementOptions}}">
      {{#each system.requirements}}
      <input type="hidden" name="system.requirements" value="{{this}}">
      {{/each}}
    </tag-input>
    {{/if}}
  </div>
</div>
<fieldset {{disabled isPlay}}>
  <legend>{{systemFields.duration.label}}</legend>
  {{formGroup systemFields.duration.fields.value value=system.duration.value}}
  {{formGroup systemFields.duration.fields.unit value=system.duration.unit}}
</fieldset>
{{formGroup systemFields.castingTime value=system.castingTime disabled=isPlay}}
{{formGroup systemFields.recharge value=system.recharge disabled=isPlay}}
