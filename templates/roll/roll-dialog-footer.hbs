<footer class="form-footer">
  <div class="roll-modifiers">
    <div class="form-group slim">
      <label>{{localize "MYTHCRAFT.Roll.SituationalTA.Label"}}</label>
      <div class="form-fields">
        <input type="number" name="situationalTA" value="{{situationalTA}}" min="0" step="1">
      </div>
    </div>
    <div class="form-group slim">
      <label>{{localize "MYTHCRAFT.Roll.SituationalTD.Label"}}</label>
      <div class="form-fields">
        <input type="number" name="situationalTD" value="{{situationalTD}}" min="0" step="1">
      </div>
    </div>
  </div>
  <button type="submit">
    <i class="fa-solid fa-dice-d10"></i> {{localize "MYTHCRAFT.Roll.Button"}}
  </button>
  <div class="roll-mode-buttons split-button">
    {{#each rollModes as |rollMode|}}
    <button
      type="button"
      class="{{ifThen (eq @root.rollMode @key) "selected" ""}} ui-control icon {{rollMode.icon}}"
      data-action="setRollMode"
      data-roll-mode="{{@key}}"
      data-tooltip="{{rollMode.label}}">
    </button>
    {{/each}}
  </div>
</footer>
