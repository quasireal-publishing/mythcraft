{{! Body fragment included by npc-statblock.hbs (the single consolidated stat-block part). }}
{{! ===== Core: HP / AR / Death / Conditions ===== }}
{{#> "systems/mythcraft/templates/actor/partials/collapsible-section.hbs" sectionId="core" label=(localize "MYTHCRAFT.SHEET.Core") collapsed=@root.collapsed.core}}
<div class="core-stats flexrow">
  <fieldset class="hit-points">
    <legend>{{systemFields.hp.label}}</legend>
    {{formGroup systemFields.hp.fields.value value=systemSource.hp.value classes="stacked slim"}}
    {{formGroup systemFields.hp.fields.shield value=systemSource.hp.shield classes="stacked slim"}}
    {{formGroup
    systemFields.hp.fields.max
    value=(ifThen isPlay system.hp.max systemSource.hp.max)
    disabled=isPlay
    classes="stacked slim"
    }}
  </fieldset>
  {{formGroup
  systemFields.defenses.fields.ar
  value=system.defenses.ar
  hint=""
  classes="stacked slim"
  disabled=isPlay
  }}
  {{#if (or system.death.max (not isPlay))}}
  <fieldset class="death-points">
    <legend>{{systemFields.death.label}}</legend>
    {{formGroup systemFields.death.fields.value value=systemSource.death.value classes="stacked slim"}}
    {{formGroup
    systemFields.death.fields.max
    value=(ifThen isPlay system.death.max systemSource.death.max)
    disabled=isPlay
    classes="stacked slim"
    }}
  </fieldset>
  {{/if}}
</div>

<fieldset class="conditions">
  <legend>{{localize "MYTHCRAFT.Conditions.Widget.Label"}}</legend>
  <condition-input
    data-conditions="{{json activeConditions}}"
    data-suggestions="{{json conditionOptions}}"
  ></condition-input>
</fieldset>
{{/"systems/mythcraft/templates/actor/partials/collapsible-section.hbs"}}

{{! ===== Attributes & Defenses ===== }}
{{#> "systems/mythcraft/templates/actor/partials/collapsible-section.hbs" sectionId="attributes" label=(localize "MYTHCRAFT.SHEET.AttributesSection") collapsed=@root.collapsed.attributes}}
<div class="attributes">
  {{! All attributes on a single row — no physical/mental group labels. }}
  <div class="attribute-group flexrow">
    {{#each attributeInfo as |group|}}
    {{#each group.list}}
    <fieldset class="attribute attribute-circle" data-attribute="{{field.name}}">
      <legend {{#if check}}data-action="rollAttribute"{{/if}}>
        {{field.label}}
        {{#if check}}<i class="fa-solid fa-dice-d20"></i>{{/if}}
        {{numberFormat value sign=true}}
      </legend>
      <a class="edit-attribute-btn icon fa-solid fa-gear" data-action="editAttribute"
        data-tooltip="{{localize 'MYTHCRAFT.SHEET.EditAttribute'}}"></a>
      {{#if defense}}
      <dl class="skills">
        <dt>{{defense.label}}</dt>
        <dd>{{defense.value}}</dd>
      </dl>
      {{/if}}
    </fieldset>
    {{/each}}
    {{/each}}
  </div>
</div>
{{/"systems/mythcraft/templates/actor/partials/collapsible-section.hbs"}}

{{! ===== Skills ===== }}
{{#> "systems/mythcraft/templates/actor/partials/collapsible-section.hbs" sectionId="skills" label=(localize "MYTHCRAFT.SHEET.Skills") collapsed=@root.collapsed.skills}}
<div class="npc-skill-grid">
  {{#each skillList}}
  <div class="npc-skill-row" data-skill="{{id}}">
    <a class="npc-skill-roll" data-skill="{{id}}" data-action="rollSkill">
      <i class="fa-solid fa-dice-d20"></i> {{label}}
    </a>
    {{#if @root.isPlay}}
    {{! Play mode: show the effective bonus as plain text so calculated and overridden values look identical. }}
    <span class="npc-skill-bonus">{{numberFormat bonus sign=true}}</span>
    {{else}}
    <input
      type="number"
      class="npc-skill-override"
      name="system.skills.{{id}}.override"
      value="{{override}}"
      placeholder="{{calculated}}"
      data-tooltip="{{localize 'MYTHCRAFT.Actor.npc.SkillOverrideHint'}}"
    >
    {{/if}}
  </div>
  {{else}}
  <p class="hint">{{localize 'MYTHCRAFT.SHEET.EditAttribute'}}</p>
  {{/each}}
</div>
{{/"systems/mythcraft/templates/actor/partials/collapsible-section.hbs"}}

{{! ===== Speed & Senses ===== }}
{{#> "systems/mythcraft/templates/actor/partials/collapsible-section.hbs" sectionId="exploration" label=(localize "MYTHCRAFT.SHEET.Exploration") collapsed=@root.collapsed.exploration}}
<div class="flexrow exploration">
  {{formGroup systemFields.movement value=systemSource.movement disabled=isPlay}}
  {{formGroup systemFields.senses value=systemSource.senses disabled=isPlay}}
</div>
{{/"systems/mythcraft/templates/actor/partials/collapsible-section.hbs"}}

{{! ===== Traits & Damage Modifications ===== }}
{{#> "systems/mythcraft/templates/actor/partials/collapsible-section.hbs" sectionId="damageMods" label=(localize "MYTHCRAFT.SHEET.DamageModifications") collapsed=@root.collapsed.damageMods}}
{{! In play mode, only rows with data render (declutters simple stat blocks). }}
{{#if (or (not isPlay) system.traits.size)}}
<div class="form-group">
  <label>{{systemFields.traits.label}}</label>
  <div class="form-fields">
    {{#if isPlay}}
    <span class="tags-display">{{join system.traits ", "}}</span>
    {{else}}
    <tag-input name="system.traits" data-suggestions="{{json traitOptions}}">
      {{#each systemSource.traits}}
      <input type="hidden" name="system.traits" value="{{this}}">
      {{/each}}
    </tag-input>
    {{/if}}
  </div>
</div>
{{/if}}

<fieldset class="damage-modification">
  <legend>{{systemFields.damage.label}}</legend>
  {{#if (or (not isPlay) system.damage.affinity.size)}}
  <div class="form-group">
    <label>{{systemFields.damage.fields.affinity.label}}</label>
    <div class="form-fields">
      {{#if isPlay}}
      <span class="tags-display">{{join system.damage.affinity ", "}}</span>
      {{else}}
      <tag-input name="system.damage.affinity" data-suggestions="{{json damageTypeOptions}}">
        {{#each systemSource.damage.affinity}}
        <input type="hidden" name="system.damage.affinity" value="{{this}}">
        {{/each}}
      </tag-input>
      {{/if}}
    </div>
  </div>
  {{/if}}
  {{#if (or (not isPlay) system.damage.resist)}}
  {{formGroup systemFields.damage.fields.resist value=systemSource.damage.resist disabled=isPlay}}
  {{/if}}
  {{#if (or (not isPlay) system.damage.immune.size)}}
  <div class="form-group">
    <label>{{systemFields.damage.fields.immune.label}}</label>
    <div class="form-fields">
      {{#if isPlay}}
      <span class="tags-display">{{join system.damage.immune ", "}}</span>
      {{else}}
      <tag-input name="system.damage.immune" data-suggestions="{{json damageTypeOptions}}">
        {{#each systemSource.damage.immune}}
        <input type="hidden" name="system.damage.immune" value="{{this}}">
        {{/each}}
      </tag-input>
      {{/if}}
    </div>
  </div>
  {{/if}}
  {{#if (or (not isPlay) system.damage.vulnerable)}}
  {{formGroup systemFields.damage.fields.vulnerable value=systemSource.damage.vulnerable disabled=isPlay}}
  {{/if}}
  {{#if (or (not isPlay) system.damage.reduction)}}
  {{formGroup systemFields.damage.fields.reduction value=systemSource.damage.reduction disabled=isPlay}}
  {{/if}}
  {{#if (or (not isPlay) system.damage.threshold)}}
  {{formGroup systemFields.damage.fields.threshold value=systemSource.damage.threshold disabled=isPlay}}
  {{/if}}
</fieldset>
{{/"systems/mythcraft/templates/actor/partials/collapsible-section.hbs"}}
